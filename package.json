{
    "name": "flujo-de-fondos",
    "version": "1.0.0",
    "description": "",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder"
    },
    "keywords": [],
    "author": "Axel Rullo",
    "license": "ISC",
    "type": "commonjs",
    "devDependencies": {
        "electron": "^40.8.0",
        "electron-builder": "^26.8.1"
    },
    "build": {
        "appId": "com.axelrullo.flujo-de-fondos",
        "productName": "Flujo de Fondos",
        "files": [
            "main.js",
            "preload.js",
            "router.js",
            "index.html",
            "package.json",
            "Icons/**/*",
            "Scripts/**/*",
            "Styles/**/*",
            "Theme/**/*",
            "Views/**/*"
        ],
        "win": {
            "target": "nsis",
            "icon": "Icons/logo.ico"
        },
        "mac": {
            "target": "dmg"
        },
        "linux": {
            "target": "AppImage"
        }
    }
}
