{
    "name": "flujo-de-fondos",
    "version": "1.0.0",
    "description": "",
    "main": "main.js",

    "scripts": {
        "start": "electron .",
        "build:backend": "cd Backend/flujodefondos && mvnw.cmd package -DskipTests -q && copy target\\flujodefondos.jar ..\\flujodefondos.jar",
        "build": "npm run build:backend && electron-builder"
    },

    "keywords": [],
    "author": "Axel Rullo",
    "license": "ISC",
    "type": "commonjs",

    "dependencies": {
        "electron-updater": "^6.8.3"
    },

    "devDependencies": {
        "electron": "^40.8.0",
        "electron-builder": "^26.8.1"
    },

    "build": {
        "appId": "com.axelrullo.flujo-de-fondos",
        "productName": "Flujo de Fondos",

        "files": [
            "main.js",
            "preload.js",
            "router.js",
            "index.html",
            "package.json",

            "Icons/**/*",
            "Scripts/**/*",
            "Styles/**/*",
            "Theme/**/*",
            "Views/**/*"
        ],

        "extraResources": [
            {
                "from": "Backend/flujodefondos.jar",
                "to": "Backend/flujodefondos.jar"
            }
        ],

        "win": {
            "target": "nsis",
            "icon": "Icons/logo.ico"
        },

        "mac": {
            "target": "dmg"
        },

        "linux": {
            "target": "AppImage"
        }
    }
}